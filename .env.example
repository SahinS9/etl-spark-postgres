# ===============================
# Database configuration
# ===============================
# SQLAlchemy-compatible database URL
# Example (DO NOT COMMIT REAL VALUES):
# postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ===============================
# External API configuration
# ===============================
# Base URL for external REST API
API_BASE_URL=https://jsonplaceholder.typicode.com

# API key if required (optional for this project)
API_KEY=

# ===============================
# Runtime / operational settings
# ===============================
# HTTP timeout in seconds for API calls
HTTP_TIMEOUT_SECONDS=30

# User-Agent header for outbound HTTP requests
USER_AGENT=etl-miniproject/1.0
